PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Empty = use bundled spec at src/schema/data360-api.bundled.yaml
DATACLOUD_OPENAPI_PATH=
DATACLOUD_DOCS_PATH=
DATACLOUD_API_BASE_URL=https://login.salesforce.com
DATACLOUD_ACCEPT_HEADER=application/json
SCHEMA_REFRESH_MS=21600000
CATALOG_CACHE_PATH=/tmp/datacloud-catalog-cache.json

ALLOW_WRITES=false
REQUEST_TIMEOUT_MS=15000
MAX_RETRIES=2
READ_CACHE_TTL_MS=5000
EXECUTE_MAX_BODY_BYTES=48000
EXECUTE_BODY_PREVIEW_CHARS=6000
USER_ID_HEADER=x-user-id

SANDBOX_TIMEOUT_MS=15000
SANDBOX_MAX_OUTPUT_BYTES=96000
SANDBOX_FETCH_TIMEOUT_MS=15000

TOKEN_STORE_PATH=/tmp/datacloud-tokens.json
TOKEN_ENCRYPTION_KEY_BASE64=

# -- OAuth web flow (existing) --
SALESFORCE_OAUTH_CLIENT_ID=
SALESFORCE_OAUTH_CLIENT_SECRET=
SALESFORCE_OAUTH_SCOPE=api cdp_query_api cdp_profile_api cdp_ingest_api refresh_token
SALESFORCE_OAUTH_AUTHORIZE_URL=https://login.salesforce.com/services/oauth2/authorize
SALESFORCE_OAUTH_TOKEN_URL=https://login.salesforce.com/services/oauth2/token
SALESFORCE_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback
DATACLOUD_TOKEN_EXCHANGE_PATH=/services/a360/token

# -- d360-compatible auth (same env vars as d360-mcp-server) --
# access_token | client_credentials | username_password | auto | oauth
CDP_AUTH_FLOW=auto
CDP_LOGIN_URL=https://login.salesforce.com
CDP_CLIENT_ID=
CDP_CLIENT_SECRET=
CDP_USERNAME=
CDP_PASSWORD=
CDP_ACCESS_TOKEN=
CDP_INSTANCE_URL=
