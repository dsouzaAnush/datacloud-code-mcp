{
  "name": "datacloud-code-mode-mcp",
  "version": "0.2.0",
  "description": "Salesforce Data Cloud (Data360) MCP server with Code Mode — search + execute in ~1k tokens",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json && cp src/schema/*.yaml dist/schema/",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:token": "node scripts/seed-token-for-datacloud.mjs",
    "smoke:mcp": "node scripts/mcp-smoke-test.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "salesforce",
    "datacloud",
    "data360",
    "code-mode",
    "oauth"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
